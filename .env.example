# Silver Tier AI Employee -- Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is in .gitignore -- NEVER commit real credentials.

# ── Anthropic (Required for AI reasoning) ─────────────────────────────────
# Get key from: https://console.anthropic.com/settings/keys
# Alternative: Use Ollama (local AI) - set to empty to disable
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Gmail Watcher (IMAP - reads emails) ───────────────────────────────────
# Setup: Enable 2FA → Create App Password at https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=you@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Email Sender (SMTP - sends replies) ──────────────────────────────────
# Same as above or different email for sending
# Required for auto-reply automation
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── WhatsApp (managed via Playwright session -- no API key needed) ───────
# Session stored at: silver_tier/silver_tier/whatsapp_session/
# Run once: python whatsapp_watcher.py --setup

# ── LinkedIn (managed via Playwright session -- no API key needed) ───────
# Session stored at: silver_tier/silver_tier/linkedin_session/
# Company page slug (for company posts)
LINKEDIN_COMPANY_SLUG=your-company-slug

# ── Optional: Ollama (Local AI - free alternative to Anthropic) ─────────
# Install: https://ollama.com/download/windows
# Then run: ollama pull llama3.2
# Set to empty string to use Anthropic instead
OLLAMA_MODEL=
OLLAMA_BASE_URL=http://localhost:11434

# ════════════════════════════════════════════════════════════════════════════
# GOLD TIER — Additional Services
# ════════════════════════════════════════════════════════════════════════════

# ── Odoo ERP Integration (odoo_mcp.py) ────────────────────────────────────
# Self-hosted Odoo Community: https://www.odoo.com/page/community
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# ── Twitter / X API (twitter_mcp.py) ──────────────────────────────────────
# Get credentials at: https://developer.twitter.com/en/portal/dashboard
# Requires Twitter Developer account (free tier available)
TWITTER_API_KEY=your-api-key-here
TWITTER_API_SECRET=your-api-secret-here
TWITTER_ACCESS_TOKEN=your-access-token-here
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret-here
TWITTER_BEARER_TOKEN=your-bearer-token-here

# ── Facebook & Instagram (facebook_instagram_mcp.py) ──────────────────────
# Get credentials at: https://developers.facebook.com/
# Requires a Facebook App with pages_manage_posts permission
# Use Graph API Explorer to get a Page Access Token
FACEBOOK_ACCESS_TOKEN=your-page-access-token-here
FACEBOOK_PAGE_ID=your-facebook-page-id
INSTAGRAM_USER_ID=your-instagram-business-user-id

# ── Slack (slack_mcp.py) ──────────────────────────────────────────────────────
# Create a Slack App at: https://api.slack.com/apps
# Bot Token (xoxb-) scopes: chat:write, channels:read, files:upload, channels:history
# User Token (xoxp-) scopes: users.profile:write, search:read
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_USER_TOKEN=xoxp-your-user-token-here
SLACK_DEFAULT_CHANNEL=general

# ── Google Calendar (calendar_mcp.py) ────────────────────────────────────────
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID → Desktop App → Download JSON
# 3. Save as credentials.json in D:/gold_tier/
# 4. Run: python calendar_mcp.py --auth   (opens browser for consent)
# token.json is auto-saved after first auth — no manual entry needed.
GOOGLE_CALENDAR_CREDENTIALS_PATH=D:/gold_tier/credentials.json

# ── Business Config ───────────────────────────────────────────────────────────
BUSINESS_CURRENCY=PKR
HIGH_VALUE_THRESHOLD=10000
BUSINESS_HOURS_START=10
BUSINESS_HOURS_END=19
WA_REPLY_TARGET_MINS=120

# ── LinkedIn Personal Profile URL ─────────────────────────────────────────────
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/your-profile/
